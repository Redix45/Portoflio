---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Fotografia Nieruchomości",
    "description": "Portfolio fotografii nieruchomości - domy, apartamenty, wnętrza komercyjne",
    "url": "https://jankobus.com/real_estate/",
    "creator": {
        "@type": "Person",
        "name": "Jan Kobus"
    }
};
---
<BaseLayout
    title="Fotografia Nieruchomości Lubliniec | Jan Kobus - Zdjęcia Domów i Apartamentów"
    description="Profesjonalna fotografia nieruchomości Lubliniec i okolice. Zdjęcia domów, apartamentów, wnętrz komercyjnych. Fotograf nieruchomości Jan Kobus - województwo śląskie."
    keywords="fotografia nieruchomości lubliniec, zdjęcia domów lubliniec, fotograf nieruchomości śląskie, fotografia wnętrz lubliniec, Jan Kobus, zdjęcia apartamentów"
    canonical="https://jankobus.com/real_estate/"
    ogType="website"
    ogImage="https://jankobus.com/photos/Vero%20Homes/Domek%201/DSC04557-HDR.jpg"
    twitterCard="summary_large_image"
    structuredData={structuredData}
    geoRegion="PL-SL"
    geoPlacename="Lubliniec"
>
    <nav>
        <div class="nav-left">
            <a href="/#work">Prace</a>
            <a href="/o-mnie">O mnie</a>
            <a href="/kontakt">Kontakt</a>
        </div>
        <div class="nav-center">
            <a href="/">Jan Kobus</a>
        </div>
        <div class="nav-right">
            <a href="https://www.facebook.com/profile.php?id=61587671346611" target="_blank"><i class="fab fa-facebook-f"></i></a>
            <a href="https://www.instagram.com/redix.45/" target="_blank">
                <i class="fab fa-instagram"></i>
            </a>
        </div>
        <button class="nav-hamburger" aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </nav>

    <header class="hero">
        <div class="hero-center">
            <h1>Nieruchomości</h1>
            <p class="subtitle">Fotografia Nieruchomości</p>
        </div>
        <div class="scroll-down">
            <i class="fas fa-chevron-down"></i>
        </div>
    </header>

    <section class="gallery" id="work">

        <!-- Vero Homes -->
        <div class="gallery-container fade-in-section">
            <div class="gallery-item">
                <a href="/vero-homes">
                    <picture>
                        <source srcset="/photos/Vero%20Homes/Domek%201/DSC04646-HDR-2.webp" type="image/webp" />
                        <img
                            src="/photos/Vero%20Homes/Domek%201/DSC04646-HDR-2.jpg"
                            alt="Fotografia nieruchomości Vero Homes - domki na wynajem Jan Kobus"
                            loading="eager"
                            fetchpriority="high"
                            decoding="async"
                        />
                    </picture>
                </a>
            </div>
            <div class="caption-box">
                <div class="caption-title">Vero Homes</div>
                <div class="caption-year">2026</div>
            </div>
        </div>

        <!-- Tu dodajesz kolejne sesje - skopiuj blok gallery-container powyżej -->

    </section>

    <footer>
        <div class="footer-content">
            <p>&copy; 2026 Jan Kobus. Wszelkie prawa zastrzeżone.</p>
            <div class="footer-socials">
                <a href="https://www.facebook.com/profile.php?id=61587671346611" target="_blank"><i class="fab fa-facebook-f"></i></a>
                <a href="https://www.instagram.com/redix.45/" target="_blank"><i class="fab fa-instagram"></i></a>
            </div>
        </div>
    </footer>

    <script is:inline>
        document.querySelector('.scroll-down')?.addEventListener('click', function() {
            document.getElementById('work')?.scrollIntoView({ behavior: 'smooth' });
        });
    </script>
</BaseLayout>
